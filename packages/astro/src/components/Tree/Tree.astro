---
import type { TreeItem } from './TreeItem';
import TreeNode from './TreeNode.astro';
interface Props {
	items: TreeItem[];
	class?: string;
	[key: string]: any;
}

const { items = [], class: className = '', ...rest } = Astro.props as Props;
---

<div class={`tree ${className}`} {...rest}>
	<TreeNode items={items} />
</div>
