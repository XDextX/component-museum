---
interface Props {
	type?: string;
	placeholder?: string;
	disabled?: boolean;
	size?: 'sm' | 'md' | 'lg';
	variant?: 'outline' | 'filled' | 'underline';
	state?: 'default' | 'success' | 'error' | 'warning';
	class?: string;
	[key: string]: any;
}

const {
	type = 'text',
	placeholder = '',
	disabled = false,
	size = 'md',
	variant = 'outline',
	state = 'default',
	class: className = '',
	...rest
} = Astro.props as Props;

const sizeClass = `input-${size}`;
const variantClass = `input-${variant}`;
const stateClass = state !== 'default' ? `input-${state}` : '';
const finalClass = `input ${sizeClass} ${variantClass} ${stateClass} ${className}`;
---

<input
	type={type as any}
	placeholder={placeholder}
	disabled={disabled}
	class={finalClass}
	{...rest}
/>
