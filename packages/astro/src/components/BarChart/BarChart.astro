---
/**
 * DataPoint - Represents a single data point in the chart
 * @typedef {Object} DataPoint
 * @property {string} label - The label for the data point
 * @property {number} value - The numerical value of the data point
 */

/**
 * BarChart Component
 *
 * A simple bar chart component that renders data as vertical bars using SVG.
 * No external dependencies required - uses pure SVG rendering.
 *
 * @component
 * @example
 * const data = [
 *   { label: 'Jan', value: 65 },
 *   { label: 'Feb', value: 59 },
 *   { label: 'Mar', value: 80 },
 * ];
 * return <BarChart data={data} title="Monthly Sales" />
 *
 * @param {DataPoint[]} data - Array of data points to display
 * @param {string} [title] - Optional title for the chart
 * @param {number} [height=300] - Height of the chart in pixels
 * @param {number} [width=500] - Width of the chart in pixels
 * @param {string[]} [colors] - Array of hex colors for the bars
 * @param {string} [class] - Additional CSS classes
 * @returns {JSX.Element} The BarChart component
 */
interface DataPoint {
	label: string;
	value: number;
}

interface Props {
	data: DataPoint[];
	title?: string;
	height?: number;
	width?: number;
	colors?: string[];
	class?: string;
	[key: string]: any;
}

const {
	data = [],
	title = '',
	height = 300,
	width = 500,
	colors = ['#3b82f6', '#ef4444', '#10b981', '#f59e0b', '#8b5cf6', '#ec4899'],
	class: className = '',
	...rest
} = Astro.props as Props;

const padding = 60;
const chartWidth = width - padding * 2;
const chartHeight = height - padding * 2;

const maxValue = Math.max(...data.map((d) => d.value));
const barWidth = chartWidth / (data.length * 1.5);
const barSpacing = (chartWidth - barWidth * data.length) / (data.length + 1);

const yAxisTicks = 5;
const maxTick = Math.ceil(maxValue / 10) * 10;
const tickInterval = maxTick / yAxisTicks;
---

<div class={`barchart ${className}`} {...rest}>
	{title && <h3 class='barchart-title'>{title}</h3>}
	<svg {height} {width} class='barchart-svg'>
		<!-- Y Axis -->
		<line
			x1={padding}
			y1={padding}
			x2={padding}
			y2={height - padding}
			stroke='#d1d5db'
			stroke-width='2'></line>
		<!-- X Axis -->
		<line
			x1={padding}
			y1={height - padding}
			x2={width - padding}
			y2={height - padding}
			stroke='#d1d5db'
			stroke-width='2'></line>

		<!-- Y Axis Ticks and Labels -->
		{
			Array.from({ length: yAxisTicks + 1 }).map((_, i) => {
				const value = i * tickInterval;
				const y = height - padding - (value / maxTick) * chartHeight;
				return (
					<>
						<line
							x1={padding - 5}
							y1={y}
							x2={padding}
							y2={y}
							stroke='#d1d5db'
							stroke-width='1'
						/>
						<text
							x={padding - 10}
							y={y + 5}
							text-anchor='end'
							font-size='12'
							fill='#6b7280'
						>
							{Math.round(value)}
						</text>
					</>
				);
			})
		}

		<!-- Bars -->
		{
			data.map((item, index) => {
				const barHeight = (item.value / maxTick) * chartHeight;
				const x = padding + barSpacing + index * (barWidth + barSpacing);
				const y = height - padding - barHeight;
				const color = colors[index % colors.length];

				return (
					<>
						<rect
							{x}
							{y}
							width={barWidth}
							height={barHeight}
							fill={color}
							opacity='0.8'
							class='barchart-bar'
						/>
						<text
							x={x + barWidth / 2}
							y={height - padding + 20}
							text-anchor='middle'
							font-size='12'
							fill='#374151'
						>
							{item.label}
						</text>
					</>
				);
			})
		}
	</svg>
</div>
