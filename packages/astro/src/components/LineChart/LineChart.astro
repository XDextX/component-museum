---
import type { DataPoint, Dataset } from './types';

/**
 * LineChart Component
 *
 * A line chart component that renders data as continuous lines with point markers using SVG.
 * Supports single or multiple datasets. Includes grid lines and automatic axis scaling.
 *
 * @component
 * @example
 * // Single dataset (legacy)
 * const data = [
 *   { label: 'Jan', value: 15 },
 *   { label: 'Feb', value: 18 },
 * ];
 * return <LineChart data={data} title="Trend" />
 *
 * @example
 * // Multiple datasets
 * const datasets = [
 *   { label: 'Series A', data: [{label: 'Jan', value: 15}, ...] },
 *   { label: 'Series B', data: [{label: 'Jan', value: 20}, ...] },
 * ];
 * return <LineChart datasets={datasets} title="Comparison" />
 *
 * @param {DataPoint[]} [data] - Array of data points (single series, legacy)
 * @param {Dataset[]} [datasets] - Array of datasets for multi-series
 * @param {string} [title] - Optional title for the chart
 * @param {number} [height=300] - Height of the chart in pixels
 * @param {number} [width=500] - Width of the chart in pixels
 * @param {string} [color='#3b82f6'] - Hex color for single line (legacy)
 * @param {string[]} [colors] - Color palette for datasets
 * @param {string} [class] - Additional CSS classes
 */

interface Props {
	data?: DataPoint[];
	datasets?: Dataset[];
	title?: string;
	height?: number;
	width?: number;
	color?: string;
	colors?: string[];
	class?: string;
	[key: string]: any;
}

const {
	data = undefined,
	datasets = undefined,
	title = '',
	height = 300,
	width = 500,
	color = '#3b82f6',
	colors: colorPalette = ['#3b82f6', '#ef4444', '#10b981', '#f59e0b', '#8b5cf6', '#ec4899'],
	class: className = '',
	...rest
} = Astro.props as Props;

// Convert legacy single dataset to new format
let allDatasets: Dataset[] = [];
if (data && data.length > 0) {
	allDatasets = [{ label: '', data, color }];
} else if (datasets && datasets.length > 0) {
	allDatasets = datasets;
}

const padding = 60;
const chartWidth = width - padding * 2;
const chartHeight = height - padding * 2;

// Calculate min/max across all datasets
let globalMin = Infinity;
let globalMax = -Infinity;

allDatasets.forEach((dataset) => {
	dataset.data.forEach((point) => {
		globalMin = Math.min(globalMin, point.value);
		globalMax = Math.max(globalMax, point.value);
	});
});

const minValue = globalMin === Infinity ? 0 : globalMin;
const maxValue = globalMax === -Infinity ? 1 : globalMax;
const range = maxValue - minValue || 1;
const maxTick = Math.ceil(maxValue / 10) * 10;

// Process each dataset into path data and points
const datasetLines = allDatasets.map((dataset, datasetIndex) => {
	const lineColor = dataset.color || colorPalette[datasetIndex % colorPalette.length];

	const points = dataset.data.map((item, index) => {
		const x = padding + (index / (dataset.data.length - 1 || 1)) * chartWidth;
		const y = height - padding - (((item.value - minValue) / range) * chartHeight || 0);
		return { x, y, ...item };
	});

	const pathData = points
		.map((p, i) => `${i === 0 ? 'M' : 'L'} ${p.x} ${p.y}`)
		.join(' ');

	return {
		label: dataset.label,
		color: lineColor,
		pathData,
		points,
	};
});

const yAxisTicks = 5;
const tickInterval = maxTick / yAxisTicks;
---

<div class={`linechart ${className}`} {...rest}>
	{title && <h3 class='linechart-title'>{title}</h3>}
	<div class='linechart-wrapper'>
		<svg {height} {width} class='linechart-svg'>
			<!-- Y Axis -->
			<line
				x1={padding}
				y1={padding}
				x2={padding}
				y2={height - padding}
				stroke='#d1d5db'
				stroke-width='2'></line>
			<!-- X Axis -->
			<line
				x1={padding}
				y1={height - padding}
				x2={width - padding}
				y2={height - padding}
				stroke='#d1d5db'
				stroke-width='2'></line>

			<!-- Y Axis Ticks and Labels -->
			{
				Array.from({ length: yAxisTicks + 1 }).map((_, i) => {
					const value = i * tickInterval;
					const y = height - padding - (value / maxTick) * chartHeight;
					return (
						<>
							<line
								x1={padding - 5}
								y1={y}
								x2={padding}
								y2={y}
								stroke='#d1d5db'
								stroke-width='1'
							/>
							<text
								x={padding - 10}
								y={y + 5}
								text-anchor='end'
								font-size='12'
								fill='#6b7280'
							>
								{Math.round(value)}
							</text>
						</>
					);
				})
			}

			<!-- Grid Lines -->
			{
				Array.from({ length: yAxisTicks + 1 }).map((_, i) => {
					const value = i * tickInterval;
					const y = height - padding - (value / maxTick) * chartHeight;
					return (
						<line
							x1={padding}
							y1={y}
							x2={width - padding}
							y2={y}
							stroke='#f3f4f6'
							stroke-width='1'
							stroke-dasharray='4'
						/>
					);
				})
			}

			<!-- Lines and Points for each dataset -->
			{
				datasetLines.map((line) => (
					<>
						<!-- Line -->
						<path
							d={line.pathData}
							fill='none'
							stroke={line.color}
							stroke-width='2'
							stroke-linecap='round'
							stroke-linejoin='round'></path>

						<!-- Points -->
						{
							line.points.map((point) => (
								<circle
									cx={point.x}
									cy={point.y}
									r='4'
									fill={line.color}
									class='linechart-point'
								/>
							))
						}
					</>
				))
			}

			<!-- Labels (from first dataset's X-axis) -->
			{
				datasetLines[0] &&
					datasetLines[0].points.map((point) => (
						<text
							x={point.x}
							y={height - padding + 20}
							text-anchor='middle'
							font-size='12'
							fill='#374151'
						>
							{point.label}
						</text>
					))
			}
		</svg>

		<!-- Legend for multiple datasets -->
		{
			datasetLines.length > 1 && (
				<div class='linechart-legend'>
					{
						datasetLines.map((line) => (
							<div class='linechart-legend-item'>
								<div
									class='linechart-legend-color'
									style={`background-color: ${line.color}`}
								/>
								<span class='linechart-legend-label'>{line.label}</span>
							</div>
						))
					}
				</div>
			)
		}
	</div>
</div>
