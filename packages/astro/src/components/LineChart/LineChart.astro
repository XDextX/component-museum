---
/**
 * DataPoint - Represents a single data point in the chart
 * @typedef {Object} DataPoint
 * @property {string} label - The label for the data point
 * @property {number} value - The numerical value of the data point
 */

/**
 * LineChart Component
 *
 * A line chart component that renders data as a continuous line with point markers using SVG.
 * Includes grid lines and automatic axis scaling.
 *
 * @component
 * @example
 * const data = [
 *   { label: 'Jan', value: 15 },
 *   { label: 'Feb', value: 18 },
 *   { label: 'Mar', value: 22 },
 * ];
 * return <LineChart data={data} title="Temperature Trend" />
 *
 * @param {DataPoint[]} data - Array of data points to display
 * @param {string} [title] - Optional title for the chart
 * @param {number} [height=300] - Height of the chart in pixels
 * @param {number} [width=500] - Width of the chart in pixels
 * @param {string} [color='#3b82f6'] - Hex color for the line
 * @param {string} [class] - Additional CSS classes
 * @returns {JSX.Element} The LineChart component
 */
interface DataPoint {
	label: string;
	value: number;
}

interface Props {
	data: DataPoint[];
	title?: string;
	height?: number;
	width?: number;
	color?: string;
	class?: string;
	[key: string]: any;
}

const {
	data = [],
	title = '',
	height = 300,
	width = 500,
	color = '#3b82f6',
	class: className = '',
	...rest
} = Astro.props as Props;

const padding = 60;
const chartWidth = width - padding * 2;
const chartHeight = height - padding * 2;

const maxValue = Math.max(...data.map((d) => d.value));
const minValue = Math.min(...data.map((d) => d.value));
const range = maxValue - minValue || 1;
const maxTick = Math.ceil(maxValue / 10) * 10;

const points = data.map((item, index) => {
	const x = padding + (index / (data.length - 1 || 1)) * chartWidth;
	const y =
		height - padding - (((item.value - minValue) / range) * chartHeight || 0);
	return { x, y, ...item };
});

const pathData = points
	.map((p, i) => `${i === 0 ? 'M' : 'L'} ${p.x} ${p.y}`)
	.join(' ');

const yAxisTicks = 5;
const tickInterval = maxTick / yAxisTicks;
---

<div class={`linechart ${className}`} {...rest}>
	{title && <h3 class='linechart-title'>{title}</h3>}
	<svg {height} {width} class='linechart-svg'>
		<!-- Y Axis -->
		<line
			x1={padding}
			y1={padding}
			x2={padding}
			y2={height - padding}
			stroke='#d1d5db'
			stroke-width='2'></line>
		<!-- X Axis -->
		<line
			x1={padding}
			y1={height - padding}
			x2={width - padding}
			y2={height - padding}
			stroke='#d1d5db'
			stroke-width='2'></line>

		<!-- Y Axis Ticks and Labels -->
		{
			Array.from({ length: yAxisTicks + 1 }).map((_, i) => {
				const value = i * tickInterval;
				const y = height - padding - (value / maxTick) * chartHeight;
				return (
					<>
						<line
							x1={padding - 5}
							y1={y}
							x2={padding}
							y2={y}
							stroke='#d1d5db'
							stroke-width='1'
						/>
						<text
							x={padding - 10}
							y={y + 5}
							text-anchor='end'
							font-size='12'
							fill='#6b7280'
						>
							{Math.round(value)}
						</text>
					</>
				);
			})
		}

		<!-- Grid Lines -->
		{
			Array.from({ length: yAxisTicks + 1 }).map((_, i) => {
				const value = i * tickInterval;
				const y = height - padding - (value / maxTick) * chartHeight;
				return (
					<line
						x1={padding}
						y1={y}
						x2={width - padding}
						y2={y}
						stroke='#f3f4f6'
						stroke-width='1'
						stroke-dasharray='4'
					/>
				);
			})
		}

		<!-- Line -->
		<path
			d={pathData}
			fill='none'
			stroke={color}
			stroke-width='2'
			stroke-linecap='round'
			stroke-linejoin='round'></path>

		<!-- Points -->
		{
			points.map((point) => (
				<circle
					cx={point.x}
					cy={point.y}
					r='4'
					fill={color}
					class='linechart-point'
				/>
			))
		}

		<!-- Labels -->
		{
			points.map((point) => (
				<text
					x={point.x}
					y={height - padding + 20}
					text-anchor='middle'
					font-size='12'
					fill='#374151'
				>
					{point.label}
				</text>
			))
		}
	</svg>
</div>
