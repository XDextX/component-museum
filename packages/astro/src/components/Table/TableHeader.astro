---
import type { Column } from './types';

interface Props {
	tableId: string;
	columns: Column[];
	sortable?: boolean;
}

const { tableId, columns, sortable = true } = Astro.props;

const ATTR = {
	ID: 'data-table-id',
	SORT: 'data-table-sort',
	COLUMN: 'data-column',
};
---

<thead data-table-id={tableId} data-table-header data-sortable={sortable}>
	<tr>
		{
			columns.map((col) => (
				<th
					class={`table-th ${sortable && col.sortable ? 'sortable' : ''}`}
					data-table-sortable={sortable && col.sortable ? tableId : undefined}
					data-column={col.key}
					style={col.width ? `width: ${col.width}` : ''}
					{...(sortable && col.sortable && { 'aria-sort': 'none' })}
				>
					<div class='table-th-content'>
						{col.label}
						{sortable && col.sortable && (
							<span class='table-sort-icon' aria-hidden='true'>
								↕
							</span>
						)}
					</div>
				</th>
			))
		}
	</tr>
</thead>

<script>
	const SORT_ICON = { UP: '↑', DOWN: '↓', DEFAULT: '↕' };
	const DEBUG = false; // Cambiar a true para ver logs de debug

	document.querySelectorAll('[data-table-header]').forEach((thead) => {
		const tableId = thead.getAttribute('data-table-id');

		if (!tableId) {
			if (DEBUG) console.warn('⚠️ Falta tableId en TableHeader');
			return;
		}

		if (DEBUG) console.log('↕️ TableHeader inicializando para tabla:', tableId);

		const container = document.querySelector(`[data-table-id="${tableId}"]`);
		if (!container) {
			if (DEBUG) console.warn('⚠️ Contenedor no encontrado');
			return;
		}

		thead.querySelectorAll(`[data-table-sortable="${tableId}"]`).forEach((el) => {
			el.addEventListener('click', () => {
				const column = el.getAttribute('data-column');
				if (DEBUG) console.log('↕️ Sort clicked en columna:', column);
				container.dispatchEvent(
					new CustomEvent('table:sort-change', {
						detail: { column },
						bubbles: true,
					}),
				);
			});
		});

		container.addEventListener('table:state-update', (e) => {
			if (DEBUG) console.log('↕️ TableHeader recibiendo actualización');
			const { state } = e.detail;
			thead.querySelectorAll('.table-sort-icon').forEach((el) => {
				const th = el.closest('th');
				if (!th) return;
				const col = th.getAttribute('data-column');
				if (col === state.sortBy) {
					el.textContent = state.sortDir === 'asc' ? SORT_ICON.UP : SORT_ICON.DOWN;
					el.classList.add('active');
				} else {
					el.textContent = SORT_ICON.DEFAULT;
					el.classList.remove('active');
				}
			});
		});

		if (DEBUG) console.log('✨ TableHeader inicializado correctamente');
	});
</script>
