---
import type { Column, TableState } from './types';
import TableControls from './TableControls.astro';
import TableHeader from './TableHeader.astro';
import TableBody from './TableBody.astro';
import TablePagination from './TablePagination.astro';

interface Props {
	columns: Column[];
	data: Record<string, any>[];
	pageSize?: number;
	searchable?: boolean;
	filterable?: boolean;
	sortable?: boolean;
	paginated?: boolean;
	striped?: boolean;
	hoverable?: boolean;
	class?: string;
	[key: string]: any;
}

const {
	columns,
	data,
	pageSize = 10,
	searchable = true,
	filterable = true,
	sortable = true,
	paginated = true,
	striped = true,
	hoverable = true,
	class: className = '',
	...rest
} = Astro.props as Props;

const tableId = `table-${Math.random().toString(36).substr(2, 9)}`;

const filterSelectOptions: Record<
	string,
	Array<{ label: string; value: string }>
> = {};

columns.forEach((col) => {
	if (col.filterable) {
		const values = new Set(data.map((row) => String(row[col.key] || '')));
		filterSelectOptions[col.key] = Array.from(values)
			.sort()
			.map((value) => ({ label: value, value }));
	}
});

const initialState: TableState = {
	sortBy: null,
	sortDir: 'asc',
	currentPage: 1,
	pageSize,
	searchQuery: '',
	filters: {},
};

const ATTR = {
	ID: 'data-table-id',
	SEARCH: 'data-table-search',
	SORT: 'data-table-sort',
	FILTER: 'data-table-filter',
	CLEAR: 'data-table-clear',
	FILTER_CLEAR: 'data-table-filter-clear',
	PAGINATION: 'data-table-pagination',
	COLUMN: 'data-column',
	ACTION: 'data-action',
	CURRENT_PAGE: 'data-table-current-page',
	TOTAL_PAGES: 'data-table-total-pages',
};
---

<div class={`table-container ${className}`} {...rest} data-table-id={tableId}>
	<TableControls
		{tableId}
		{columns}
		{searchable}
		{filterable}
		{filterSelectOptions}
	/>

	<div class='table-wrapper'>
		<table
			class={`table ${striped ? 'table-striped' : ''} ${hoverable ? 'table-hoverable' : ''}`}
		>
			<TableHeader {tableId} {columns} {sortable} />
			<TableBody {tableId} {columns} data={data} />
		</table>
	</div>

	<TablePagination {tableId} {paginated} />
</div>

<script
	type='module'
	define:vars={{
		tableId,
		columns: JSON.stringify(columns),
		data: JSON.stringify(data),
		pageSize,
		sortable,
		paginated,
		initialState: JSON.stringify(initialState),
	}}
>
	const SORT_DIR = { ASC: 'asc', DESC: 'desc' };
	const ATTR = {
		ID: 'data-table-id',
		SEARCH: 'data-table-search',
		SORT: 'data-table-sort',
		FILTER: 'data-table-filter',
		CLEAR: 'data-table-clear',
		FILTER_CLEAR: 'data-table-filter-clear',
		PAGINATION: 'data-table-pagination',
		COLUMN: 'data-column',
		ACTION: 'data-action',
		CURRENT_PAGE: 'data-table-current-page',
		TOTAL_PAGES: 'data-table-total-pages',
	};

	import { TableStateManager } from '../../TableStateManager.js';

	const container = document.querySelector(`[${ATTR.ID}="${tableId}"]`);

	const notifyStateChange = (detail) => {
		const evt = new CustomEvent('table:state-update', {
			detail,
			bubbles: true,
		});
		container.dispatchEvent(evt);
	};

	const manager = new TableStateManager(
		JSON.parse(columns),
		JSON.parse(data),
		{
			state: JSON.parse(initialState),
			pageSize,
			sortable,
			paginated,
		},
		notifyStateChange,
	);

	container.addEventListener('table:search', (e) => {
		manager.setState({ searchQuery: e.detail.toLowerCase(), currentPage: 1 });
		manager.applyFiltersAndSort();
	});

	container.addEventListener('table:sort-change', (e) => {
		const { column } = e.detail;
		if (manager.state.sortBy === column) {
			manager.state.sortDir =
				manager.state.sortDir === SORT_DIR.ASC ? SORT_DIR.DESC : SORT_DIR.ASC;
		} else {
			manager.state.sortBy = column;
			manager.state.sortDir = SORT_DIR.ASC;
		}

		manager.setState({ ...manager.state, currentPage: 1 });
		manager.applyFiltersAndSort();
	});

	container.addEventListener('table:filter-change', (e) => {
		const { column, values } = e.detail;
		if (values.length === 0) {
			delete manager.state.filters[column];
		} else {
			manager.state.filters[column] = values;
		}
		manager.setState({ ...manager.state, currentPage: 1 });
		manager.applyFiltersAndSort();
	});

	container.addEventListener('table:pagination', (e) => {
		const { action } = e.detail;
		const totalPages = Math.ceil(manager.filteredData.length / manager.pageSize);
		if (action === 'prev' && manager.state.currentPage > 1) {
			manager.state.currentPage--;
		} else if (action === 'next' && manager.state.currentPage < totalPages) {
			manager.state.currentPage++;
		}
		notifyStateChange({
			state: manager.state,
			filteredData: manager.filteredData,
			totalPages: Math.ceil(manager.filteredData.length / manager.pageSize),
		});
	});

	container.addEventListener('table:clear-all', () => {
		manager.setState({ searchQuery: '', filters: {}, currentPage: 1 });
		manager.applyFiltersAndSort();
		const searchEl = document.querySelector(`[${ATTR.SEARCH}="${tableId}"]`);
		if (searchEl) searchEl.value = '';
	});

	container.addEventListener('table:clear-filter', (e) => {
		const { column } = e.detail;
		delete manager.state.filters[column];
		manager.setState({ ...manager.state, currentPage: 1 });
		manager.applyFiltersAndSort();
	});

	manager.applyFiltersAndSort();
	notifyStateChange({
		state: manager.state,
		filteredData: manager.filteredData,
		totalPages: Math.ceil(manager.filteredData.length / manager.pageSize),
	});
</script>
