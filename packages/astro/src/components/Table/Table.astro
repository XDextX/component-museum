---
import type { Column, TableState } from './types';
import TableControls from './TableControls.astro';
import TableHeader from './TableHeader.astro';
import TableBody from './TableBody.astro';
import TablePagination from './TablePagination.astro';

interface Props {
	columns: Column[];
	data: Record<string, any>[];
	pageSize?: number;
	searchable?: boolean;
	filterable?: boolean;
	sortable?: boolean;
	paginated?: boolean;
	striped?: boolean;
	hoverable?: boolean;
	class?: string;
	[key: string]: any;
}

const {
	columns,
	data,
	pageSize = 10,
	searchable = true,
	filterable = true,
	sortable = true,
	paginated = true,
	striped = true,
	hoverable = true,
	class: className = '',
	...rest
} = Astro.props as Props;

// Generate unique ID for this table instance
const tableId = `table-${Math.random().toString(36).substr(2, 9)}`;

// Extract unique values for each filterable column
const filterSelectOptions: Record<
	string,
	Array<{ label: string; value: string }>
> = {};

columns.forEach((col) => {
	if (col.filterable) {
		const values = new Set(data.map((row) => String(row[col.key] || '')));
		filterSelectOptions[col.key] = Array.from(values)
			.sort()
			.map((value) => ({ label: value, value }));
	}
});

// Initial state
const initialState: TableState = {
	sortBy: null,
	sortDir: 'asc',
	currentPage: 1,
	pageSize,
	searchQuery: '',
	filters: {},
};

// Constants for data attributes and UI
const ATTR = {
	ID: 'data-table-id',
	SEARCH: 'data-table-search',
	SORT: 'data-table-sort',
	FILTER: 'data-table-filter',
	CLEAR: 'data-table-clear',
	FILTER_CLEAR: 'data-table-filter-clear',
	PAGINATION: 'data-table-pagination',
	COLUMN: 'data-column',
	ACTION: 'data-action',
	CURRENT_PAGE: 'data-table-current-page',
	TOTAL_PAGES: 'data-table-total-pages',
};

const PAGINATION_ACTION = { PREV: 'prev', NEXT: 'next' };
---

<div class={`table-container ${className}`} {...rest} data-table-id={tableId}>
	<TableControls
		{tableId}
		{columns}
		{searchable}
		{filterable}
		{filterSelectOptions}
	/>

	<div class='table-wrapper'>
		<table
			class={`table ${striped ? 'table-striped' : ''} ${hoverable ? 'table-hoverable' : ''}`}
		>
			<TableHeader {tableId} {columns} {sortable} />
			<TableBody {columns} data={data} />
		</table>
	</div>

	<TablePagination {tableId} {paginated} />
</div>

<script define:vars={{ tableId, columns: JSON.stringify(columns), data: JSON.stringify(data), pageSize, sortable, paginated, initialState: JSON.stringify(initialState) }}>
	const SORT_DIR = { ASC: 'asc', DESC: 'desc' };
	const SORT_ICON = { UP: '↑', DOWN: '↓', DEFAULT: '↕' };
	const ATTR = {
		ID: 'data-table-id',
		SEARCH: 'data-table-search',
		SORT: 'data-table-sort',
		FILTER: 'data-table-filter',
		CLEAR: 'data-table-clear',
		FILTER_CLEAR: 'data-table-filter-clear',
		PAGINATION: 'data-table-pagination',
		COLUMN: 'data-column',
		ACTION: 'data-action',
		CURRENT_PAGE: 'data-table-current-page',
		TOTAL_PAGES: 'data-table-total-pages',
	};
	const PAGINATION_ACTION = { PREV: 'prev', NEXT: 'next' };

	function debounce(fn, delay) {
		let timeoutId;
		return function (...args) {
			clearTimeout(timeoutId);
			timeoutId = setTimeout(() => fn.apply(this, args), delay);
		};
	}

	class TableController {
		constructor() {
			this.tableId = tableId;
			this.columns = JSON.parse(columns);
			this.data = JSON.parse(data);
			this.pageSize = pageSize;
			this.sortable = sortable;
			this.paginated = paginated;
			this.state = JSON.parse(initialState);
			this.filteredData = this.data;
			this.container = null;
			this.init();
		}

		init() {
			this.container = document.querySelector(`[${ATTR.ID}="${this.tableId}"]`);
			if (!this.container) return;
			this.attachEventListeners();
			this.render();
		}

		attachEventListeners() {
			if (this.sortable) {
				this.container.querySelectorAll(`[${ATTR.SORT}="${this.tableId}"]`).forEach((el) => {
					el.addEventListener('click', (e) => this.handleSort(e));
				});
			}

			const searchInput = this.container.querySelector(`[${ATTR.SEARCH}="${this.tableId}"]`);
			if (searchInput) {
				searchInput.addEventListener('input', debounce((e) => this.handleSearch(e), 300));
			}

			this.container.querySelectorAll(`[${ATTR.FILTER}="${this.tableId}"]`).forEach((el) => {
				const multiSelect = el.closest('.multiselect');
				if (multiSelect) {
					const checkboxes = multiSelect.querySelectorAll('input[type="checkbox"]');
					checkboxes.forEach((checkbox) => {
						checkbox.addEventListener('change', () => this.handleFilter({ currentTarget: el }));
					});
				} else {
					el.addEventListener('change', (e) => this.handleFilter(e));
				}
			});

			const clearBtn = this.container.querySelector(`[${ATTR.CLEAR}="${this.tableId}"]`);
			if (clearBtn) clearBtn.addEventListener('click', () => this.handleClearAll());

			this.container.querySelectorAll(`[${ATTR.FILTER_CLEAR}="${this.tableId}"]`).forEach((el) => {
				el.addEventListener('click', (e) => this.handleClearFilter(e));
			});

			if (this.paginated) {
				this.container.querySelectorAll(`[${ATTR.PAGINATION}="${this.tableId}"]`).forEach((el) => {
					el.addEventListener('click', (e) => this.handlePagination(e));
				});
			}
		}

		handleSort(e) {
			const column = e.currentTarget.dataset.column;
			if (this.state.sortBy === column) {
				this.state.sortDir = this.state.sortDir === SORT_DIR.ASC ? SORT_DIR.DESC : SORT_DIR.ASC;
			} else {
				this.state.sortBy = column;
				this.state.sortDir = SORT_DIR.ASC;
			}
			this.state.currentPage = 1;
			this.applyFiltersAndSort();
			this.render();
		}

		handleSearch(e) {
			this.state.searchQuery = e.target.value.toLowerCase();
			this.state.currentPage = 1;
			this.applyFiltersAndSort();
			this.render();
		}

		handleFilter(e) {
			const column = e.currentTarget.dataset.column;
			const multiSelectContainer = e.currentTarget.closest('.multiselect');
			let selected = [];

			if (multiSelectContainer) {
				// New MultiSelect component with checkboxes
				const checkboxes = multiSelectContainer.querySelectorAll(
					'input[type="checkbox"]:checked',
				);
				selected = Array.from(checkboxes).map((cb) => cb.value);
			} else {
				// Fallback for native select (if ever used)
				selected = Array.from(e.currentTarget.selectedOptions).map((o) => o.value);
			}

			if (selected.length === 0) {
				delete this.state.filters[column];
			} else {
				this.state.filters[column] = selected;
			}
			this.state.currentPage = 1;
			this.applyFiltersAndSort();
			this.render();
		}

		handlePagination(e) {
			const action = e.currentTarget.dataset.action;
			const totalPages = Math.ceil(this.filteredData.length / this.pageSize);

			if (action === PAGINATION_ACTION.PREV && this.state.currentPage > 1) {
				this.state.currentPage--;
			} else if (
				action === PAGINATION_ACTION.NEXT &&
				this.state.currentPage < totalPages
			) {
				this.state.currentPage++;
			}
			this.render();
		}

		handleClearAll() {
			this.state.searchQuery = '';
			this.state.filters = {};
			this.state.currentPage = 1;

			const searchInput = this.container.querySelector(
				`[${ATTR.SEARCH}="${this.tableId}"]`,
			);
			if (searchInput) {
				searchInput.value = '';
			}

			this.container
				.querySelectorAll(`[${ATTR.FILTER}="${this.tableId}"]`)
				.forEach((el) => {
					this.clearMultiSelectFilter(el);
				});

			this.applyFiltersAndSort();
			this.render();
		}

		handleClearFilter(e) {
			const column = e.currentTarget.dataset.column;
			delete this.state.filters[column];
			this.state.currentPage = 1;

			const multiSelectContainer = this.container.querySelector(
				`[${ATTR.FILTER}="${this.tableId}"][${ATTR.COLUMN}="${column}"]`,
			);
			if (multiSelectContainer) {
				this.clearMultiSelectFilter(multiSelectContainer);
			}

			this.applyFiltersAndSort();
			this.render();
		}

		clearMultiSelectFilter(filterElement) {
			const multiSelect = filterElement.closest('.multiselect');
			if (multiSelect) {
				const checkboxes = multiSelect.querySelectorAll('input[type="checkbox"]');
				checkboxes.forEach((cb) => {
					cb.checked = false;
				});
				const input = multiSelect.querySelector('.multiselect-input');
				if (input) {
					input.value = '';
				}
			}
		}

		applyFiltersAndSort() {
			const hasSearchQuery = this.state.searchQuery.length > 0;
			const hasFilters = Object.keys(this.state.filters).length > 0;

			let filtered = this.data;
			if (hasSearchQuery || hasFilters) {
				filtered = this.data.filter((row) => {
					if (hasSearchQuery) {
						const matchesSearch = this.columns.some((col) =>
							String(row[col.key] || '')
								.toLowerCase()
								.includes(this.state.searchQuery),
						);
						if (!matchesSearch) return false;
					}

					if (hasFilters) {
						const matchesFilters = Object.entries(this.state.filters).every(
							([column, values]) => values.includes(String(row[column] || '')),
						);
						if (!matchesFilters) return false;
					}

					return true;
				});
			}

			if (this.sortable && this.state.sortBy) {
				filtered.sort((a, b) => {
					const aVal = a[this.state.sortBy];
					const bVal = b[this.state.sortBy];

					if (aVal < bVal) return this.state.sortDir === SORT_DIR.ASC ? -1 : 1;
					if (aVal > bVal) return this.state.sortDir === SORT_DIR.ASC ? 1 : -1;
					return 0;
				});
			}

			this.filteredData = filtered;
		}

		render() {
			let pageData = this.filteredData;
			let totalPages = 1;

			if (this.paginated) {
				const start = (this.state.currentPage - 1) * this.pageSize;
				pageData = this.filteredData.slice(start, start + this.pageSize);
				totalPages = Math.ceil(this.filteredData.length / this.pageSize);
			}

			const tbody = this.container.querySelector(`[${ATTR.ID}="${this.tableId}"] tbody`);
			tbody.innerHTML = '';

			if (pageData.length === 0) {
				const emptyRow = document.createElement('tr');
				const emptyCell = document.createElement('td');
				emptyCell.setAttribute('colspan', this.columns.length);
				emptyCell.className = 'table-empty';
				emptyCell.textContent = 'No data available';
				emptyRow.appendChild(emptyCell);
				tbody.appendChild(emptyRow);
			} else {
				pageData.forEach((row) => {
					const tr = document.createElement('tr');
					this.columns.forEach((col) => {
						const td = document.createElement('td');
						td.className = 'table-td';
						td.textContent = row[col.key] || '';
						tr.appendChild(td);
					});
					tbody.appendChild(tr);
				});
			}

			if (this.paginated) {
				const currentPageEl = this.container.querySelector(`[${ATTR.CURRENT_PAGE}="${this.tableId}"]`);
				const totalPagesEl = this.container.querySelector(`[${ATTR.TOTAL_PAGES}="${this.tableId}"]`);
				if (currentPageEl) currentPageEl.textContent = this.state.currentPage;
				if (totalPagesEl) totalPagesEl.textContent = totalPages || 1;

				const prevBtn = this.container.querySelector(`[${ATTR.PAGINATION}="${this.tableId}"][${ATTR.ACTION}="prev"]`);
				const nextBtn = this.container.querySelector(`[${ATTR.PAGINATION}="${this.tableId}"][${ATTR.ACTION}="next"]`);
				if (prevBtn) prevBtn.disabled = this.state.currentPage === 1;
				if (nextBtn) nextBtn.disabled = this.state.currentPage === totalPages || totalPages === 0;
			}

			if (this.sortable) {
				this.container.querySelectorAll(`[${ATTR.SORT}="${this.tableId}"] .table-sort-icon`).forEach((el) => {
					const col = el.parentElement.parentElement.dataset.column;
					if (col === this.state.sortBy) {
						el.textContent = this.state.sortDir === SORT_DIR.ASC ? SORT_ICON.UP : SORT_ICON.DOWN;
						el.classList.add('active');
					} else {
						el.textContent = SORT_ICON.DEFAULT;
						el.classList.remove('active');
					}
				});
			}
		}
	}

	new TableController();
</script>
