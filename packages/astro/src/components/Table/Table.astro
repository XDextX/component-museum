---
import type { Column, TableState } from './types';
import Button from '../Button/Button.astro';
import MultiSelect from '../MultiSelect/MultiSelect.astro';

/**
 * Table Component
 *
 * A comprehensive data table component with sorting, pagination, search, and filtering.
 *
 * @component
 * @example
 * const columns = [
 *   { key: 'id', label: 'ID', sortable: true },
 *   { key: 'name', label: 'Name', sortable: true, filterable: true },
 *   { key: 'status', label: 'Status', sortable: true, filterable: true },
 * ];
 * const data = [
 *   { id: 1, name: 'John', status: 'Active' },
 *   { id: 2, name: 'Jane', status: 'Inactive' },
 * ];
 * return <Table columns={columns} data={data} />
 *
 * @param {Column[]} columns - Column definitions
 * @param {Record<string, any>[]} data - Array of row objects
 * @param {number} [pageSize=10] - Rows per page
 * @param {boolean} [searchable=true] - Enable search
 * @param {boolean} [filterable=true] - Enable filtering
 * @param {boolean} [striped=true] - Striped row colors
 * @param {boolean} [hoverable=true] - Hover row effect
 * @param {string} [class] - Additional CSS classes
 */

interface Props {
	columns: Column[];
	data: Record<string, any>[];
	pageSize?: number;
	searchable?: boolean;
	filterable?: boolean;
	sortable?: boolean;
	paginated?: boolean;
	striped?: boolean;
	hoverable?: boolean;
	class?: string;
	[key: string]: any;
}

const {
	columns,
	data,
	pageSize = 10,
	searchable = true,
	filterable = true,
	sortable = true,
	paginated = true,
	striped = true,
	hoverable = true,
	class: className = '',
	...rest
} = Astro.props as Props;

// Generate unique ID for this table instance
const tableId = `table-${Math.random().toString(36).substr(2, 9)}`;

// Extract unique values for each filterable column
const filterSelectOptions: Record<
	string,
	Array<{ label: string; value: string }>
> = {};

columns.forEach((col) => {
	if (col.filterable) {
		const values = new Set(data.map((row) => String(row[col.key] || '')));
		filterSelectOptions[col.key] = Array.from(values)
			.sort()
			.map((value) => ({ label: value, value }));
	}
});

// Initial state
const initialState: TableState = {
	sortBy: null,
	sortDir: 'asc',
	currentPage: 1,
	pageSize,
	searchQuery: '',
	filters: {},
};

// Constants for data attributes and UI
const ATTR = {
	ID: 'data-table-id',
	SEARCH: 'data-table-search',
	SORT: 'data-table-sort',
	FILTER: 'data-table-filter',
	CLEAR: 'data-table-clear',
	FILTER_CLEAR: 'data-table-filter-clear',
	PAGINATION: 'data-table-pagination',
	COLUMN: 'data-column',
	ACTION: 'data-action',
	CURRENT_PAGE: 'data-table-current-page',
	TOTAL_PAGES: 'data-table-total-pages',
};

const PAGINATION_ACTION = { PREV: 'prev', NEXT: 'next' };
---

<div class={`table-container ${className}`} {...rest} data-table-id={tableId}>
	<!-- Search and Filter Controls -->
	{
		(searchable || filterable) && (
			<div class='table-controls'>
				<div class='table-controls-top'>
					{searchable && (
						<input
							type='search'
							class='table-search-input'
							placeholder='Search...'
							data-table-search={tableId}
						/>
					)}
					{(searchable || filterable) && (
						<Button
							variant='secondary'
							size='sm'
							data-table-clear={tableId}
							title='Clear all filters and search'
						>
							Clear Filters
						</Button>
					)}
				</div>
				{filterable && (
					<div class='table-filters'>
						{columns.map((col) =>
							col.filterable ? (
								<div class='table-filter-group'>
									<div class='table-filter-header'>
										<label class='table-filter-label'>{col.label}</label>
										<Button
											variant='outline'
											size='sm'
											data-table-filter-clear={tableId}
											data-column={col.key}
											title={`Clear ${col.label} filter`}
											class='table-filter-clear-btn'
										>
											✕
										</Button>
									</div>
									<MultiSelect
										options={filterSelectOptions[col.key]}
										placeholder={`Filter by ${col.label}`}
										variant='outline'
										size='sm'
										data-table-filter={tableId}
										data-column={col.key}
									/>
								</div>
							) : null,
						)}
					</div>
				)}
			</div>
		)
	}

	<!-- Table -->
	<div class='table-wrapper'>
		<table
			class={`table ${striped ? 'table-striped' : ''} ${hoverable ? 'table-hoverable' : ''}`}
		>
			<thead>
				<tr>
					{
						columns.map((col) => (
							<th
								class={`table-th ${sortable && col.sortable ? 'sortable' : ''}`}
								data-table-sort={sortable && col.sortable ? tableId : undefined}
								data-column={col.key}
								style={col.width ? `width: ${col.width}` : ''}
							>
								<div class='table-th-content'>
									{col.label}
									{sortable && col.sortable && <span class='table-sort-icon'>↕</span>}
								</div>
							</th>
						))
					}
				</tr>
			</thead>
			<tbody>
				{
					data.length === 0 ? (
						<tr>
							<td colspan={columns.length} class='table-empty'>
								No data available
							</td>
						</tr>
					) : (
						data.map((row, idx) => (
							<tr>
								{columns.map((col) => (
									<td class='table-td'>{row[col.key]}</td>
								))}
							</tr>
						))
					)
				}
			</tbody>
		</table>
	</div>

	<!-- Pagination -->
	{
		paginated && (
			<div class='table-pagination'>
				<Button
					variant='outline'
					size='sm'
					data-table-pagination={tableId}
					data-action={PAGINATION_ACTION.PREV}
				>
					← Previous
				</Button>
				<div class='table-page-info'>
					Page <span data-table-current-page={tableId}>1</span> of
					<span data-table-total-pages={tableId}>1</span>
				</div>
				<Button
					variant='outline'
					size='sm'
					data-table-pagination={tableId}
					data-action={PAGINATION_ACTION.NEXT}
				>
					Next →
				</Button>
			</div>
		)
	}
</div>

<script
	define:vars={{
		tableId,
		columns: JSON.stringify(columns),
		data: JSON.stringify(data),
		pageSize,
		sortable,
		paginated,
		initialState: JSON.stringify(initialState),
		ATTR: JSON.stringify(ATTR),
		PAGINATION_ACTION: JSON.stringify(PAGINATION_ACTION),
	}}
>
	const SORT_DIR = { ASC: 'asc', DESC: 'desc' };
	const SORT_ICON = { UP: '↑', DOWN: '↓', DEFAULT: '↕' };
	const ATTR = JSON.parse(ATTR);
	const PAGINATION_ACTION = JSON.parse(PAGINATION_ACTION);

	class TableController {
		constructor() {
			this.tableId = tableId;
			this.columns = JSON.parse(columns);
			this.data = JSON.parse(data);
			this.pageSize = pageSize;
			this.sortable = sortable;
			this.paginated = paginated;
			this.state = JSON.parse(initialState);
			this.filteredData = this.data;

			this.init();
		}

		init() {
			this.attachEventListeners();
			this.render();
		}

		attachEventListeners() {
			this.container = document.querySelector(`[${ATTR.ID}="${this.tableId}"]`);
			
			if (this.sortable) {
				this.container
					.querySelectorAll(`[${ATTR.SORT}="${this.tableId}"]`)
					.forEach((el) => {
						el.addEventListener('click', (e) => this.handleSort(e));
					});
			}

			const searchInput = this.container.querySelector(
				`[${ATTR.SEARCH}="${this.tableId}"]`,
			);
			if (searchInput) {
				searchInput.addEventListener('input', (e) => this.handleSearch(e));
			}

			this.container
				.querySelectorAll(`[${ATTR.FILTER}="${this.tableId}"]`)
				.forEach((el) => {
					const multiSelect = el.closest('.multiselect');
					if (multiSelect) {
						const checkboxes = multiSelect.querySelectorAll('input[type="checkbox"]');
						checkboxes.forEach((checkbox) => {
							checkbox.addEventListener('change', (e) => {
								this.handleFilter({
									currentTarget: el,
								});
							});
						});
					} else {
						el.addEventListener('change', (e) => this.handleFilter(e));
					}
				});

			const clearBtn = this.container.querySelector(
				`[${ATTR.CLEAR}="${this.tableId}"]`,
			);
			if (clearBtn) {
				clearBtn.addEventListener('click', () => this.handleClearAll());
			}

			this.container
				.querySelectorAll(`[${ATTR.FILTER_CLEAR}="${this.tableId}"]`)
				.forEach((el) => {
					el.addEventListener('click', (e) => this.handleClearFilter(e));
				});

			if (this.paginated) {
				this.container
					.querySelectorAll(`[${ATTR.PAGINATION}="${this.tableId}"]`)
					.forEach((el) => {
						el.addEventListener('click', (e) => this.handlePagination(e));
					});
			}
		}

		handleSort(e) {
			const column = e.currentTarget.dataset.column;
			if (this.state.sortBy === column) {
				this.state.sortDir =
					this.state.sortDir === SORT_DIR.ASC ? SORT_DIR.DESC : SORT_DIR.ASC;
			} else {
				this.state.sortBy = column;
				this.state.sortDir = SORT_DIR.ASC;
			}
			this.state.currentPage = 1;
			this.applyFiltersAndSort();
			this.render();
		}

		handleSearch(e) {
			this.state.searchQuery = e.target.value.toLowerCase();
			this.state.currentPage = 1;
			this.applyFiltersAndSort();
			this.render();
		}

		handleFilter(e) {
			const column = e.currentTarget.dataset.column;
			const multiSelectContainer = e.currentTarget.closest('.multiselect');
			let selected = [];

			if (multiSelectContainer) {
				// New MultiSelect component with checkboxes
				const checkboxes = multiSelectContainer.querySelectorAll(
					'input[type="checkbox"]:checked',
				);
				selected = Array.from(checkboxes).map((cb) => cb.value);
			} else {
				// Fallback for native select (if ever used)
				selected = Array.from(e.currentTarget.selectedOptions).map((o) => o.value);
			}

			if (selected.length === 0) {
				delete this.state.filters[column];
			} else {
				this.state.filters[column] = selected;
			}
			this.state.currentPage = 1;
			this.applyFiltersAndSort();
			this.render();
		}

		handlePagination(e) {
			const action = e.currentTarget.dataset.action;
			const totalPages = Math.ceil(this.filteredData.length / this.pageSize);

			if (action === PAGINATION_ACTION.PREV && this.state.currentPage > 1) {
				this.state.currentPage--;
			} else if (
				action === PAGINATION_ACTION.NEXT &&
				this.state.currentPage < totalPages
			) {
				this.state.currentPage++;
			}
			this.render();
		}

		handleClearAll() {
			this.state.searchQuery = '';
			this.state.filters = {};
			this.state.currentPage = 1;

			const searchInput = this.container.querySelector(
				`[${ATTR.SEARCH}="${this.tableId}"]`,
			);
			if (searchInput) {
				searchInput.value = '';
			}

			this.container
				.querySelectorAll(`[${ATTR.FILTER}="${this.tableId}"]`)
				.forEach((el) => {
					this.clearMultiSelectFilter(el);
				});

			this.applyFiltersAndSort();
			this.render();
		}

		handleClearFilter(e) {
			const column = e.currentTarget.dataset.column;
			delete this.state.filters[column];
			this.state.currentPage = 1;

			const multiSelectContainer = this.container.querySelector(
				`[${ATTR.FILTER}="${this.tableId}"][${ATTR.COLUMN}="${column}"]`,
			);
			if (multiSelectContainer) {
				this.clearMultiSelectFilter(multiSelectContainer);
			}

			this.applyFiltersAndSort();
			this.render();
		}

		clearMultiSelectFilter(filterElement) {
			const multiSelect = filterElement.closest('.multiselect');
			if (multiSelect) {
				const checkboxes = multiSelect.querySelectorAll('input[type="checkbox"]');
				checkboxes.forEach((cb) => {
					cb.checked = false;
				});
				const input = multiSelect.querySelector('.multiselect-input');
				if (input) {
					input.value = '';
				}
			}
		}

		applyFiltersAndSort() {
			const hasSearchQuery = this.state.searchQuery.length > 0;
			const hasFilters = Object.keys(this.state.filters).length > 0;

			let filtered = this.data;
			if (hasSearchQuery || hasFilters) {
				filtered = this.data.filter((row) => {
					if (hasSearchQuery) {
						const matchesSearch = this.columns.some((col) =>
							String(row[col.key] || '')
								.toLowerCase()
								.includes(this.state.searchQuery),
						);
						if (!matchesSearch) return false;
					}

					if (hasFilters) {
						const matchesFilters = Object.entries(this.state.filters).every(
							([column, values]) => values.includes(String(row[column] || '')),
						);
						if (!matchesFilters) return false;
					}

					return true;
				});
			}

			if (this.sortable && this.state.sortBy) {
				filtered.sort((a, b) => {
					const aVal = a[this.state.sortBy];
					const bVal = b[this.state.sortBy];

					if (aVal < bVal) return this.state.sortDir === SORT_DIR.ASC ? -1 : 1;
					if (aVal > bVal) return this.state.sortDir === SORT_DIR.ASC ? 1 : -1;
					return 0;
				});
			}

			this.filteredData = filtered;
		}

		render() {
			let pageData;
			let totalPages = 1;

			if (this.paginated) {
				const start = (this.state.currentPage - 1) * this.pageSize;
				const end = start + this.pageSize;
				pageData = this.filteredData.slice(start, end);
				totalPages = Math.ceil(this.filteredData.length / this.pageSize);
			} else {
				pageData = this.filteredData;
			}

			const tbody = this.container.querySelector(
				`[${ATTR.ID}="${this.tableId}"] tbody`,
			);
			if (pageData.length === 0) {
				tbody.innerHTML = `<tr><td colspan="${this.columns.length}" class="table-empty">No data available</td></tr>`;
			} else {
				tbody.innerHTML = pageData
					.map(
						(row) =>
							`<tr>${this.columns
								.map((col) => `<td class="table-td">${row[col.key] || ''}</td>`)
								.join('')}</tr>`,
					)
					.join('');
			}

			if (this.paginated) {
				this.container.querySelector(
					`[data-table-current-page="${this.tableId}"]`,
				).textContent = this.state.currentPage;
				this.container.querySelector(
					`[data-table-total-pages="${this.tableId}"]`,
				).textContent = totalPages || 1;

				const prevBtn = this.container.querySelector(
					`[${ATTR.PAGINATION}="${this.tableId}"][${ATTR.ACTION}="prev"]`,
				);
				const nextBtn = this.container.querySelector(
					`[${ATTR.PAGINATION}="${this.tableId}"][${ATTR.ACTION}="next"]`,
				);
				prevBtn.disabled = this.state.currentPage === 1;
				nextBtn.disabled =
					this.state.currentPage === totalPages || totalPages === 0;
			}

			if (this.sortable) {
				this.container
					.querySelectorAll(`[${ATTR.SORT}="${this.tableId}"] .table-sort-icon`)
					.forEach((el) => {
						const col = el.parentElement.parentElement.dataset.column;
						if (col === this.state.sortBy) {
							el.textContent =
								this.state.sortDir === SORT_DIR.ASC ? SORT_ICON.UP : SORT_ICON.DOWN;
							el.classList.add('active');
						} else {
							el.textContent = SORT_ICON.DEFAULT;
							el.classList.remove('active');
						}
					});
			}
		}
	}

	// Initialize table
	new TableController();
</script>
