---
import type { Column } from './types';
import Button from '../Button/Button.astro';
import MultiSelect from '../MultiSelect/MultiSelect.astro';

interface Props {
	tableId: string;
	columns: Column[];
	searchable?: boolean;
	filterable?: boolean;
	filterSelectOptions: Record<string, Array<{ label: string; value: string }>>;
}

const {
	tableId,
	columns,
	searchable = true,
	filterable = true,
	filterSelectOptions,
} = Astro.props;
---

{
	(searchable || filterable) && (
		<div class='table-controls' data-table-controls={tableId}>
			<div class='table-controls-top'>
				{searchable && (
					<input
						type='search'
						class='table-search-input'
						placeholder='Search...'
						data-table-search={tableId}
						aria-label='Search table data'
					/>
				)}
				{(searchable || filterable) && (
					<Button
						variant='secondary'
						size='sm'
						data-table-clear={tableId}
						title='Clear all filters and search'
					>
						Clear Filters
					</Button>
				)}
			</div>
			{filterable && (
				<div class='table-filters'>
					{columns.map((col) =>
						col.filterable ? (
							<div class='table-filter-group'>
								<div class='table-filter-header'>
									<label class='table-filter-label'>{col.label}</label>
									<Button
										variant='outline'
										size='sm'
										data-table-filter-clear={tableId}
										data-column={col.key}
										title={`Clear ${col.label} filter`}
										class='table-filter-clear-btn'
									>
										✕
									</Button>
								</div>
								<MultiSelect
									options={filterSelectOptions[col.key]}
									placeholder={`Filter by ${col.label}`}
									variant='outline'
									size='sm'
									data-table-filter={tableId}
									data-column={col.key}
								/>
							</div>
						) : null,
					)}
				</div>
			)}
		</div>
	)
}

<script>
	const DEBUG = true; // Cambiar a true para ver logs de debug

	function debounce(fn: Function, delay: number) {
		let timeoutId: number;
		return function (...args: any[]) {
			clearTimeout(timeoutId);
			timeoutId = setTimeout(() => fn.apply(args), delay);
		};
	}

	document.querySelectorAll('[data-table-controls]').forEach((controls) => {
		const tableId = controls.getAttribute('data-table-controls');
		if (!tableId) return;

		if (DEBUG) console.log('🎛️ TableControls inicializando para tabla:', tableId);

		const container = document.querySelector(`[data-table-id="${tableId}"]`);
		if (!container) {
			if (DEBUG) console.warn('⚠️ Contenedor no encontrado para tabla:', tableId);
			return;
		}

		const searchInput = controls.querySelector(
			`[data-table-search="${tableId}"]`,
		);
		if (searchInput) {
			if (DEBUG) console.log('🔍 Search input encontrado');
			searchInput.addEventListener(
				'input',
				debounce((e: any) => {
					if (DEBUG) console.log('🔍 Search input event:', e.target.value);
					container.dispatchEvent(
						new CustomEvent('table:search', {
							detail: e.target.value,
							bubbles: true,
						}),
					);
				}, 300),
			);
		}

		controls.addEventListener('change', (e) => {
			const checkbox = e.target;
			if (checkbox instanceof HTMLInputElement && checkbox.type === 'checkbox') {
				const multiSelectDiv = checkbox.closest(`[data-table-filter="${tableId}"]`);
				if (multiSelectDiv) {
					if (DEBUG) console.log('🔘 Filtro cambiado');
					const column = multiSelectDiv.getAttribute('data-column');
					const selectedCheckboxes = multiSelectDiv.querySelectorAll(
						'input[type="checkbox"]:checked',
					);
					const values = Array.from(selectedCheckboxes).map(
						(cb) => (cb as HTMLInputElement).value,
					);
					container.dispatchEvent(
						new CustomEvent('table:filter-change', {
							detail: { column, values },
							bubbles: true,
						}),
					);
				}
			}
		});

		const clearBtn = controls.querySelector(`[data-table-clear="${tableId}"]`);
		if (clearBtn) {
			if (DEBUG) console.log('🧹 Clear button encontrado');
			clearBtn.addEventListener('click', () => {
				if (DEBUG) console.log('🧹 Clear all clicked');
				container.dispatchEvent(
					new CustomEvent('table:clear-all', { bubbles: true }),
				);
				controls
					.querySelectorAll(`[data-table-filter="${tableId}"]`)
					.forEach((el) => {
						const multiSelect = el.closest('.multiselect');
						if (multiSelect) {
							multiSelect.querySelectorAll('input[type="checkbox"]').forEach((cb) => {
								if (cb instanceof HTMLInputElement) {
									cb.checked = false;
								}
							});
							const input = multiSelect.querySelector(
								'.multiselect-input',
							) as HTMLInputElement | null;
							if (input) input.value = '';
						}
					});
			});
		}

		controls
			.querySelectorAll(`[data-table-filter-clear="${tableId}"]`)
			.forEach((el) => {
				el.addEventListener('click', () => {
					const column = el.getAttribute('data-column');
					if (DEBUG) console.log('❌ Clear filter clicked para columna:', column);
					const multiSelect = controls
						.querySelector(
							`[data-table-filter="${tableId}"][data-column="${column}"]`,
						)
						?.closest('.multiselect');
					if (multiSelect) {
						multiSelect.querySelectorAll('input[type="checkbox"]').forEach((cb) => {
							if (cb instanceof HTMLInputElement) {
								cb.checked = false;
							}
						});
						const input = multiSelect.querySelector(
							'.multiselect-input',
						) as HTMLInputElement | null;
						if (input) input.value = '';
					}
					container.dispatchEvent(
						new CustomEvent('table:clear-filter', {
							detail: { column },
							bubbles: true,
						}),
					);
				});
			});

		if (DEBUG) console.log('✨ TableControls inicializado correctamente');
	});
</script>
