---
import Button from '../Button/Button.astro';

interface Props {
	tableId: string;
	paginated?: boolean;
}

const { tableId, paginated = true } = Astro.props;

const PAGINATION_ACTION = { PREV: 'prev', NEXT: 'next' };
---

{
	paginated && (
		<div class='table-pagination' data-table-id={tableId} data-table-pagination>
			<Button
				variant='outline'
				size='sm'
				data-pagination-action={tableId}
				data-action={PAGINATION_ACTION.PREV}
				aria-label='Previous page'
			>
				← Previous
			</Button>
			<div class='table-page-info' role='status' aria-live='polite'>
				Page <span data-table-current-page={tableId}>1</span> of
				<span data-table-total-pages={tableId}>1</span>
			</div>
			<Button
				variant='outline'
				size='sm'
				data-pagination-action={tableId}
				data-action={PAGINATION_ACTION.NEXT}
				aria-label='Next page'
			>
				Next →
			</Button>
		</div>
	)
}

<script>
	const DEBUG = false; // Cambiar a true para ver logs de debug

	document.querySelectorAll('[data-table-pagination]').forEach((pagination) => {
		const tableId = pagination.getAttribute('data-table-id');

		if (!tableId) {
			if (DEBUG) console.warn('⚠️ Falta tableId en TablePagination');
			return;
		}

		if (DEBUG) console.log('📄 TablePagination inicializando para tabla:', tableId);

		const container = document.querySelector(`[data-table-id="${tableId}"]`);
		if (!container) {
			if (DEBUG) console.warn('⚠️ Contenedor no encontrado');
			return;
		}

		pagination.querySelectorAll(`[data-pagination-action="${tableId}"]`).forEach((btn) => {
			btn.addEventListener('click', () => {
				const action = btn.getAttribute('data-action');
				if (DEBUG) console.log('📄 Pagination action:', action);
				container.dispatchEvent(
					new CustomEvent('table:pagination', { detail: { action }, bubbles: true }),
				);
			});
		});

		container.addEventListener('table:state-update', (e) => {
			if (DEBUG) console.log('📄 TablePagination recibiendo actualización');
			const { state, totalPages } = e.detail;
			const currentPageSpan = pagination.querySelector(`[data-table-current-page="${tableId}"]`);
			const totalPagesSpan = pagination.querySelector(`[data-table-total-pages="${tableId}"]`);
			if (currentPageSpan) currentPageSpan.textContent = String(state.currentPage);
			if (totalPagesSpan) totalPagesSpan.textContent = String(totalPages);
		});

		if (DEBUG) console.log('✨ TablePagination inicializado correctamente');
	});
</script>
