---
import type { Column } from './types';

interface Props {
	tableId: string;
	columns: Column[];
	data: Record<string, any>[];
}

const { tableId, columns, data } = Astro.props;
---

<tbody>
	{
		data.length === 0 ? (
			<tr>
				<td colspan={columns.length} class='table-empty'>
					No data available
				</td>
			</tr>
		) : (
			data.map((row) => (
				<tr>
					{columns.map((col) => (
						<td class='table-td'>{row[col.key]}</td>
					))}
				</tr>
			))
		)
	}
</tbody>

<script define:vars={{ tableId, columns: JSON.stringify(columns) }}>
	const container = document.querySelector(`[data-table-id="${tableId}"]`);
	const cols = JSON.parse(columns);

	container.addEventListener('table:state-update', (e) => {
		const { state, filteredData } = e.detail;
		const pageSize = state.pageSize;

		let pageData = filteredData;
		if (filteredData.length > 0) {
			const start = (state.currentPage - 1) * pageSize;
			pageData = filteredData.slice(start, start + pageSize);
		}

		const tbody = container.querySelector('tbody');
		tbody.innerHTML = '';

		if (pageData.length === 0) {
			const emptyRow = document.createElement('tr');
			const emptyCell = document.createElement('td');
			emptyCell.setAttribute('colspan', cols.length);
			emptyCell.className = 'table-empty';
			emptyCell.textContent = 'No data available';
			emptyRow.appendChild(emptyCell);
			tbody.appendChild(emptyRow);
		} else {
			pageData.forEach((row) => {
				const tr = document.createElement('tr');
				cols.forEach((col) => {
					const td = document.createElement('td');
					td.className = 'table-td';
					td.textContent = row[col.key] || '';
					tr.appendChild(td);
				});
				tbody.appendChild(tr);
			});
		}
	});
</script>
