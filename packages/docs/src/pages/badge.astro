---
import { Badge as Comp, Code, Breadcrumb, Card } from '@component-museum/astro';
import { Navigation } from '../data/Navigation';
import { SideBarLayout } from '../layouts';
---

<SideBarLayout title='Badge Stories' navItems={Navigation}>
	<Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Badge' }]} />
	<h1 class='text-4xl font-bold mb-12'>Badge Component</h1>

	<!-- Variants -->
	<Card class='mb-16 p-0 overflow-hidden' variant='elevated'>
		<div class='bg-gray-300 p-2'>
			<h2 class='text-2xl font-bold mb-6'>Variants</h2>
		</div>
		<div class='p-2 flex flex-wrap gap-4'>
			<Comp variant='primary'>Primary</Comp>
			<Comp variant='secondary'>Secondary</Comp>
			<Comp variant='success'>Success</Comp>
			<Comp variant='warning'>Warning</Comp>
			<Comp variant='danger'>Danger</Comp>
			<Comp variant='info'>Info</Comp>
		</div>
	</Card>

	<!-- Sizes -->
	<Card class='mb-16 p-0 overflow-hidden' variant='elevated'>
		<div class='bg-gray-300 p-2'>
			<h2 class='text-2xl font-bold mb-6'>Sizes</h2>
		</div>
		<div class='flex flex-wrap gap-6 p-8 shadow items-center'>
			<div class='flex flex-col items-center gap-4'>
				<Comp size='sm'>Small</Comp>
				<Code class='text-sm text-gray-600'>size="sm"</Code>
			</div>
			<div class='flex flex-col items-center gap-4'>
				<Comp size='md'>Medium</Comp>
				<Code class='text-sm text-gray-600'>size="md"</Code>
			</div>
			<div class='flex flex-col items-center gap-4'>
				<Comp size='lg'>Large</Comp>
				<Code class='text-sm text-gray-600'>size="lg"</Code>
			</div>
		</div>
	</Card>

	<!-- Combinations -->
	<Card class='mb-16 p-0 overflow-hidden' variant='elevated'>
		<div class='bg-gray-300 p-2'>
			<h2 class='text-2xl font-bold mb-6'>Combinations</h2>
		</div>
		<div class='flex flex-wrap gap-4 p-8'>
			<Comp variant='success' size='sm'>New</Comp>
			<Comp variant='warning' size='md'>Pending</Comp>
			<Comp variant='danger' size='lg'>Critical</Comp>
			<Comp variant='info' size='sm'>Info</Comp>
			<Comp variant='primary' size='lg'>Featured</Comp>
		</div>
	</Card>

	<!-- Use Cases -->
	<Card class='mb-16 p-0 overflow-hidden' variant='elevated'>
		<div class='bg-gray-300 p-2'>
			<h2 class='text-2xl font-bold mb-6'>Use Cases</h2>
		</div>
		<div class='grid grid-cols-1 md:grid-cols-2 gap-4 p-8 shadow'>
			<div class='border-l-4 border-green-500 pl-4'>
				<h3 class='font-semibold mb-2'>Status Tags</h3>
				<p class='text-sm text-gray-600 mb-3'>Mark item status</p>
				<div class='flex gap-2'>
					<Comp variant='success'>Active</Comp>
					<Comp variant='warning'>Inactive</Comp>
				</div>
			</div>
			<div class='border-l-4 border-blue-500 pl-4'>
				<h3 class='font-semibold mb-2'>Category Tags</h3>
				<p class='text-sm text-gray-600 mb-3'>Organize content</p>
				<div class='flex gap-2'>
					<Comp variant='primary'>Feature</Comp>
					<Comp variant='secondary'>Bug</Comp>
				</div>
			</div>
		</div>
	</Card>

	<!-- Code Examples -->
	<section>
		<h2 class='text-2xl font-bold mb-6'>Usage Examples</h2>

		<Code copyable>
			{
				'---\nimport { Badge } from "@component-museum/astro";\nimport "@component-museum/astro/styles.css";\n---\n\n<!-- Basic badge -->\n<Badge>Default</Badge>\n\n<!-- With variants -->\n<Badge variant="success">Success</Badge>\n<Badge variant="danger">Danger</Badge>\n\n<!-- With sizes -->\n<Badge size="sm">Small</Badge>\n<Badge size="lg">Large</Badge>\n\n<!-- Combined -->\n<Badge variant="warning" size="lg">Warning Large</Badge>'
			}
		</Code>
	</section>
</SideBarLayout>
