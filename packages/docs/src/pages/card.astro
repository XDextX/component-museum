---
import {
	Card as Comp,
	Button,
	Badge,
	Code,
	Breadcrumb,
} from '@component-museum/astro';
import { Navigation } from '../data/Navigation';
import { SideBarLayout } from '../layouts';
---

<SideBarLayout title='Card Stories' navItems={Navigation}>
	<Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Card' }]} />
	<h1 class='text-4xl font-bold mb-12'>Card Component</h1>

	<!-- Variants -->
	<Comp class='mb-16 overflow-hidden pb-2 px-2' variant='basic'>
		<h2 class='text-2xl font-bold mb-6'>Variants</h2>
		<div class='grid grid-cols-1 md:grid-cols-3 gap-6'>
			<Comp variant='basic' class='p-6'>
				<h3 class='font-semibold mb-2'>Basic</h3>
				<p class='text-gray-600 text-sm'>Simple card</p>
			</Comp>
			<Comp variant='elevated' class='p-6'>
				<h3 class='font-semibold mb-2'>Elevated</h3>
				<p class='text-gray-600 text-sm'>Card with shadow effect</p>
			</Comp>
			<Comp variant='outlined' class='p-6'>
				<h3 class='font-semibold mb-2'>Outlined</h3>
				<p class='text-gray-600 text-sm'>Card with border</p>
			</Comp>
		</div>
	</Comp>

	<!-- Content Sections -->
	<Comp class='mb-16'>
		<h2 class='text-2xl font-bold mb-6'>Content Sections</h2>
		<div class='max-w-2xl'>
			<Comp variant='elevated' class='p-0 overflow-hidden'>
				<div class='bg-blue-600 text-white p-4'>
					<h3 class='font-semibold'>Card Header</h3>
				</div>
				<div class='p-6'>
					<p class='text-gray-700 mb-4'>
						This is the card body. You can put any content here - text, images, forms,
						etc.
					</p>
					<p class='text-gray-600 text-sm'>
						Cards are flexible containers perfect for organizing related content.
					</p>
				</div>
				<div class='bg-gray-50 p-4 flex gap-2'>
					<Button size='sm'>Save</Button>
					<Button variant='outline' size='sm'>Cancel</Button>
				</div>
			</Comp>
		</div>
	</Comp>

	<!-- Use Cases -->
	<Comp class='mb-16'>
		<h2 class='text-2xl font-bold mb-6'>Use Cases</h2>
		<div class='grid grid-cols-1 md:grid-cols-2 gap-6'>
			<Comp variant='elevated' class='p-6'>
				<div class='flex items-start gap-3 mb-3'>
					<Badge variant='success' size='sm'>Article</Badge>
					<h3 class='font-semibold'>Blog Post</h3>
				</div>
				<p class='text-gray-600 text-sm mb-4'>
					Perfect for displaying blog posts with title, excerpt, and metadata.
				</p>
				<Button variant='outline' size='sm'>Read More</Button>
			</Comp>

			<Comp variant='elevated' class='p-6'>
				<div class='flex items-start gap-3 mb-3'>
					<Badge variant='primary' size='sm'>Product</Badge>
					<h3 class='font-semibold'>Product Card</h3>
				</div>
				<p class='text-gray-600 text-sm mb-4'>
					Great for e-commerce layouts to showcase products with images and actions.
				</p>
				<Button variant='primary' size='sm'>View Product</Button>
			</Comp>

			<Comp variant='elevated' class='p-6'>
				<div class='flex items-start gap-3 mb-3'>
					<Badge variant='info' size='sm'>Feature</Badge>
					<h3 class='font-semibold'>Feature Highlight</h3>
				</div>
				<p class='text-gray-600 text-sm mb-4'>
					Highlight key features or capabilities with clean card layouts.
				</p>
				<Button variant='outline' size='sm'>Learn More</Button>
			</Comp>

			<Comp variant='elevated' class='p-6'>
				<div class='flex items-start gap-3 mb-3'>
					<Badge variant='warning' size='sm'>Alert</Badge>
					<h3 class='font-semibold'>Alert Card</h3>
				</div>
				<p class='text-gray-600 text-sm mb-4'>
					Use cards to present important information or alerts to users.
				</p>
				<Button variant='secondary' size='sm'>Dismiss</Button>
			</Comp>
		</div>
	</Comp>

	<!-- Code Examples -->
	<Comp>
		<h2 class='text-2xl font-bold mb-6'>Usage Examples</h2>
		<Code language='astro' title='Complete Example'>
			{
				'---\nimport { Card, Button } from "@component-museum/astro";\nimport "@component-museum/astro/styles.css";\n---\n\n<!-- Basic card -->\n<Card variant="elevated" class="p-6">\n\t<h3>Card Title</h3>\n\t<p>Card content goes here</p>\n</Card>\n\n<!-- Card with sections -->\n<Card variant="elevated" class="p-0 overflow-hidden">\n\t<div class="bg-blue-600 text-white p-4">\n\t\t<h3>Header</h3>\n\t</div>\n\t<div class="p-6">\n\t\t<p>Content goes here</p>\n\t</div>\n\t<div class="bg-gray-50 p-4 flex gap-2">\n\t\t<Button size="sm">Save</Button>\n\t\t<Button variant="outline" size="sm">Cancel</Button>\n\t</div>\n</Card>'
			}
		</Code>
	</Comp>
</SideBarLayout>
