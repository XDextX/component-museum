---
import { Tree } from '@component-museum/astro';
import HomeLayout from '../layouts/HomeLayout.astro';
import '../styles/global.css';
import { Navigation } from '../data/Navigation';

const navItems = Navigation.filter((item) => item.children).map((item) => ({
	...item,
	expanded: true,
}));
---

<HomeLayout title='Component Museum'>
	<div class='min-h-screen flex flex-col items-center justify-center p-8'>
		<div class='max-w-2xl'>
			<h1 class='text-5xl font-bold mb-4 text-gray-900'>Component Museum</h1>
			<p class='text-xl text-gray-600 mb-12'>
				A collection of reusable components for React and Astro
			</p>

			<div class='bg-white rounded-lg shadow p-8'>
				<Tree items={navItems} />
			</div>
		</div>
	</div>
</HomeLayout>
